rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuário lê e escreve apenas o próprio perfil (inclui fcmToken)
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // OS: condutor cria e lê as próprias; gestor lê e atualiza todas
    match /ordens-servico/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.condutorId == request.auth.uid;
      allow update: if request.auth != null;
    }

    // Fornecedores e veículos: leitura autenticada; escrita apenas para gestores
    match /fornecedores/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
    match /veiculos/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
  }
}
