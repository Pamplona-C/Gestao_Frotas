rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGestor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Cada usuário lê e escreve o próprio perfil; apenas gestores podem excluir
    match /usuarios/{uid} {
      allow read:   if isOwner(uid) || isGestor();
      allow create: if isOwner(uid) || isGestor();
      allow update: if isOwner(uid) || isGestor();
      allow delete: if isGestor();
    }

    // OS: condutor cria as próprias e atualiza só fotos; gestor atualiza tudo
    match /ordens-servico/{id} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() &&
        (request.resource.data.condutorId == request.auth.uid || isGestor());
      allow update: if isGestor() ||
        (isAuthenticated() &&
         resource.data.condutorId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fotos', 'entregueOficinaEm', 'retornouOficinaEm']));
    }

    // Fornecedores e veículos: leitura autenticada; escrita apenas para gestores
    match /fornecedores/{id} {
      allow read:  if isAuthenticated();
      allow write: if isGestor();
    }

    match /veiculos/{id} {
      allow read:  if isAuthenticated();
      allow write: if isGestor();
    }

    // Catálogo de serviços: leitura autenticada; escrita apenas para gestores
    match /catalogo-servicos/{id} {
      allow read:  if isAuthenticated();
      allow write: if isGestor();
    }

    // Vínculos condutor↔veículo: gestor cria/encerra; condutores vinculados lêem e atualizam (checklist)
    match /vinculos/{id} {
      allow read:   if isAuthenticated() &&
        (isGestor() || request.auth.uid in resource.data.condutorIds);
      allow create: if isGestor();
      allow update: if isGestor() || request.auth.uid in resource.data.condutorIds;
      allow delete: if false;
    }

    // Checklists: condutor cria o próprio; leitura autenticada; imutável após criação
    match /checklists/{id} {
      allow read:          if isAuthenticated();
      allow create:        if isAuthenticated() &&
        request.resource.data.condutorId == request.auth.uid;
      allow update, delete: if false;
    }

    // Notificações: cada usuário lê e marca como lida apenas as próprias
    match /notificacoes/{id} {
      allow read:   if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
